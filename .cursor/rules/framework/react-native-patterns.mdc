# React Native Patterns for Smart Hockey Coach

## Component Architecture

### Functional Components Only
```typescript
// ✅ ALWAYS: Typed functional components
interface ShotAnalysisProps {
  shotId: string;
  onComplete?: (analysis: ShotAnalysis) => void;
}

export const ShotAnalysis: React.FC<ShotAnalysisProps> = ({ 
  shotId, 
  onComplete 
}) => {
  // Component logic
};

// ❌ NEVER: Class components
// ❌ NEVER: Untyped components
```

### Performance Optimization

```typescript
// ✅ Memoize expensive components
export const VideoPlayback = React.memo<VideoPlaybackProps>(({ 
  videoUri, 
  timestamps 
}) => {
  // Component implementation
}, (prevProps, nextProps) => {
  // Custom comparison for video URI only
  return prevProps.videoUri === nextProps.videoUri;
});

// ✅ Stable callbacks for lists
const FeedbackList: React.FC<FeedbackListProps> = ({ items }) => {
  const renderItem = useCallback(({ item }: { item: FeedbackItem }) => (
    <FeedbackCard
      key={item.id}
      feedback={item}
      onPress={handleItemPress}
    />
  ), [handleItemPress]);
  
  const keyExtractor = useCallback((item: FeedbackItem) => item.id, []);
  
  return (
    <FlashList
      data={items}
      renderItem={renderItem}
      keyExtractor={keyExtractor}
      estimatedItemSize={120}
      getItemType={(item) => item.type} // For recycling
    />
  );
};
```

## State Management Patterns

### Local State Rules
```typescript
// ✅ Use proper state initialization
const [isRecording, setIsRecording] = useState(false);
const [shotData, setShotData] = useState<ShotData | null>(null);

// ✅ State updates with proper typing
const updateShotData = useCallback((data: Partial<ShotData>) => {
  setShotData(prev => prev ? { ...prev, ...data } : null);
}, []);

// ❌ NEVER: Direct state mutations
// ❌ NEVER: setState in render
```

### Global State (Zustand)
```typescript
// ✅ Typed store with selectors
const useFeedbackStore = create<FeedbackStore>()(
  subscribeWithSelector((set, get) => ({
    // State
    instantFeedback: null,
    fastFeedback: { raw: '', parsed: null },
    
    // Actions with proper typing
    appendFastChunk: (chunk: string) => set(state => ({
      fastFeedback: {
        ...state.fastFeedback,
        raw: state.fastFeedback.raw + chunk,
        parsed: tryParseFastFeedback(state.fastFeedback.raw + chunk)
      }
    })),
  }))
);

// ✅ Granular subscriptions
const shotOutcome = useFeedbackStore(
  state => state.fastFeedback.parsed?.outcome
);
```

## Native Module Integration

### Camera Handling
```typescript
// ✅ Proper camera setup with error handling
const CameraScreen: React.FC = () => {
  const [hasPermission, setHasPermission] = useState<boolean | null>(null);
  const cameraRef = useRef<RNCamera>(null);
  
  useEffect(() => {
    (async () => {
      const { status } = await Camera.requestCameraPermissionsAsync();
      setHasPermission(status === 'granted');
    })();
  }, []);
  
  const startRecording = useCallback(async () => {
    if (!cameraRef.current) return;
    
    try {
      const options: RecordingOptions = {
        quality: RNCamera.Constants.VideoQuality['720p'],
        maxDuration: 30,
        videoBitrate: 5 * 1000 * 1000, // 5 Mbps
      };
      
      const { uri } = await cameraRef.current.recordAsync(options);
      processVideo(uri);
    } catch (error) {
      handleRecordingError(error);
    }
  }, []);
};
```

