## Logger Hooks and Utilities

### React Hook for Logging
```typescript
// ✅ Hook for component logging
export function useLogger(component: string): ComponentLogger {
  const requestId = useRequestId();
  const userId = useUserId();
  
  const logger = useMemo(() => {
    const baseLogger = new ReactNativeLogger();
    
    return {
      log: (level: LogEntry['level'], message: string, metadata?: Record<string, unknown>) => {
        baseLogger.log({
          ...baseLogger.createEntry(level, message),
          context: {
            ...baseLogger.createEntry(level, message).context,
            component,
            operation: 'component',
            requestId,
            userId,
            metadata,
          },
        });
      },
      
      logOperation: (operation: string, fn: () => void | Promise<void>) => {
        const start = performance.now();
        const result = fn();
        
        if (result instanceof Promise) {
          return result.finally(() => {
            baseLogger.info(`${operation} completed`, {
              component,
              operation,
              performance: { duration: performance.now() - start },
            });
          });
        }
        
        baseLogger.info(`${operation} completed`, {
          component,
          operation,
          performance: { duration: performance.now() - start },
        });
      },
      
      // Convenience methods
      debug: (message: string, metadata?: Record<string, unknown>) => 
        logger.log('debug', message, metadata),
      info: (message: string, metadata?: Record<string, unknown>) => 
        logger.log('info', message, metadata),
      warn: (message: string, metadata?: Record<string, unknown>) => 
        logger.log('warn', message, metadata),
      error: (message: string, error?: Error, metadata?: Record<string, unknown>) => {
        const entry = baseLogger.createEntry('error', message, {
          component,
          operation: 'component',
          requestId,
          userId,
          metadata,
        });
        
        if (error) {
          entry.error = {
            name: error.name,
            message: error.message,
            stack: error.stack,
          };
        }
        
        baseLogger.log(entry);
      },
    };
  }, [component, requestId, userId]);
  
  return logger;
}
