// ✅ Specialized logging for shot analysis
export function logShotAnalysis(
  shotId: string,
  stage: 'start' | 'ml_detection' | 'video_process' | 'api_call' | 'complete',
  data: Record<string, unknown>
): void {
  const logger = new ReactNativeLogger();
  
  logger.info(`Shot analysis: ${stage}`, {
    component: 'shot_analysis',
    operation: stage,
    metadata: {
      shotId,
      ...data,
    },
  });
}

// Usage example
export async function analyzeShotWithLogging(video: VideoData): Promise<Result<Analysis>> {
  const shotId = generateShotId();
  const logger = useLogger('ShotAnalyzer');
  
  logShotAnalysis(shotId, 'start', { videoSize: video.size });
  
  try {
    // ML Detection
    const detectionTimer = logger.startTimer('ml_detection');
    const detection = await mlModel.detectShot(video);
    detectionTimer();
    
    if (!detection.success) {
      logger.error('ML detection failed', detection.error);
      return detection;
    }
    
    logShotAnalysis(shotId, 'ml_detection', {
      shotType: detection.data.type,
      confidence: detection.data.confidence,
    });
    
    // Continue with analysis...
    
  } catch (error) {
    logger.error('Shot analysis failed', error as Error, { shotId });
    return Err(error as Error);
  }
}
