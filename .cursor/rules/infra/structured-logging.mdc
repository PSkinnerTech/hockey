## Log Queries and Analysis

```typescript
// ✅ Helpers for analyzing logs
export interface LogQuery {
  level?: LogEntry['level'];
  component?: string;
  operation?: string;
  userId?: string;
  timeRange?: {
    start: Date;
    end: Date;
  };
}

export async function queryLogs(query: LogQuery): Promise<LogEntry[]> {
  // Implementation depends on logging backend
  const filters = buildFilters(query);
  const logs = await logStorage.query(filters);
  return logs;
}

export async function analyzePerformance(
  operation: string,
  timeRange?: { start: Date; end: Date }
): Promise<PerformanceAnalysis> {
  const logs = await queryLogs({
    operation,
    timeRange,
  });
  
  const durations = logs
    .filter(log => log.performance?.duration)
    .map(log => log.performance!.duration!);
  
  return {
    count: durations.length,
    avg: average(durations),
    p50: percentile(durations, 0.5),
    p95: percentile(durations, 0.95),
    p99: percentile(durations, 0.99),
    max: Math.max(...durations),
    min: Math.min(...durations),
  };
}
