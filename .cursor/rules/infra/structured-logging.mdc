# Structured Logging for Smart Hockey Coach

## Logger Implementation

### Base Logger Interface
```typescript
// ✅ Type-safe structured logger
export interface LogContext {
  // Request context
  requestId: string;
  userId?: string;
  sessionId?: string;
  
  // Component context
  component: string;
  operation: string;
  
  // Platform context
  platform: 'ios' | 'android' | 'web';
  version: string;
  environment: 'development' | 'staging' | 'production';
  
  // Custom metadata
  metadata?: Record<string, unknown>;
}

export interface LogEntry {
  timestamp: string;
  level: 'debug' | 'info' | 'warn' | 'error' | 'fatal';
  message: string;
  context: LogContext;
  error?: {
    name: string;
    message: string;
    stack?: string;
    code?: string;
  };
  performance?: {
    duration?: number;
    memoryUsage?: number;
  };
}

export abstract class BaseLogger {
  constructor(protected baseContext: Partial<LogContext>) {}
  
  abstract log(entry: LogEntry): void;
  
  protected createEntry(
    level: LogEntry['level'],
    message: string,
    context?: Partial<LogContext>
  ): LogEntry {
    return {
      timestamp: new Date().toISOString(),
      level,
      message,
      context: {
        ...this.baseContext,
        ...context,
        requestId: context?.requestId || this.baseContext.requestId || generateRequestId(),
      } as LogContext,
    };
  }
}
```

### React Native Logger
```typescript
// ✅ React Native specific logger
import { Platform } from 'react-native';
import DeviceInfo from 'react-native-device-info';
import crashlytics from '@react-native-firebase/crashlytics';

export class ReactNativeLogger extends BaseLogger {
  constructor() {
    super({
      platform: Platform.OS as 'ios' | 'android',
      version: DeviceInfo.getVersion(),
      environment: __DEV__ ? 'development' : 'production',
    });
  }
  
  log(entry: LogEntry): void {
    // Development: Pretty print to console
    if (__DEV__) {
      const color = this.getLogColor(entry.level);
      console.log(
        `%c[${entry.level.toUpperCase()}] ${entry.message}`,
        `color: ${color}`,
        entry.context,
        entry.error
      );
      return;
    }
    
    // Production: Send to logging service
    this.sendToLoggingService(entry);
    
    // Errors go to Crashlytics
    if (entry.level === 'error' || entry.level === 'fatal') {
      crashlytics().log(JSON.stringify(entry));
      if (entry.error) {
        crashlytics().recordError(new Error(entry.error.message));
      }
    }
  }
  
  private sendToLoggingService(entry: LogEntry): void {
    // Batch logs for performance
    LogBatcher.add(entry);
  }
  
  private getLogColor(level: LogEntry['level']): string {
    const colors = {
      debug: '#888',
      info: '#2196F3',
      warn: '#FF9800',
      error: '#F44336',
      fatal: '#9C27B0',
    };
    return colors[level];
  }
  
  // Convenience methods
  debug(message: string, context?: Partial<LogContext>): void {
    this.log(this.createEntry('debug', message, context));
  }
  
  info(message: string, context?: Partial<LogContext>): void {
    this.log(this.createEntry('info', message, context));
  }
  
  warn(message: string, context?: Partial<LogContext>): void {
    this.log(this.createEntry('warn', message, context));
  }
  
  error(message: string, error?: Error, context?: Partial<LogContext>): void {
    const entry = this.createEntry('error', message, context);
    if (error) {
      entry.error = {
        name: error.name,
        message: error.message,
        stack: error.stack,
        code: (error as any).code,
      };
    }
    this.log(entry);
  }
}
