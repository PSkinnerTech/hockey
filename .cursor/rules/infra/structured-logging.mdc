### Convex Logger
```typescript
// ✅ Server-side logger for Convex
export class ConvexLogger extends BaseLogger {
  constructor(environment: string) {
    super({
      platform: 'web', // Convex runs in edge environment
      version: process.env.CONVEX_DEPLOYMENT || 'unknown',
      environment: environment as any,
    });
  }
  
  log(entry: LogEntry): void {
    // Structured JSON output for log aggregation
    console.log(JSON.stringify(entry));
    
    // Send to external service if configured
    if (process.env.LOG_ENDPOINT) {
      this.sendToExternalService(entry);
    }
  }
  
  private async sendToExternalService(entry: LogEntry): Promise<void> {
    try {
      await fetch(process.env.LOG_ENDPOINT!, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(entry),
      });
    } catch (error) {
      // Fail silently to avoid affecting main flow
      console.error('Failed to send log', error);
    }
  }
}
