### Performance Logging
```typescript
// ✅ Performance monitoring with logging
export class PerformanceLogger {
  private static metrics = new Map<string, number[]>();
  
  static measure<T>(
    operation: string,
    fn: () => T | Promise<T>
  ): T | Promise<T> {
    const start = performance.now();
    const logger = new ReactNativeLogger();
    
    try {
      const result = fn();
      
      if (result instanceof Promise) {
        return result.finally(() => {
          this.recordMetric(operation, start, logger);
        });
      }
      
      this.recordMetric(operation, start, logger);
      return result;
      
    } catch (error) {
      logger.error(`Performance measurement failed: ${operation}`, error as Error);
      throw error;
    }
  }
  
  private static recordMetric(
    operation: string,
    start: number,
    logger: ReactNativeLogger
  ): void {
    const duration = performance.now() - start;
    
    // Store metric
    const metrics = this.metrics.get(operation) || [];
    metrics.push(duration);
    if (metrics.length > 100) metrics.shift();
    this.metrics.set(operation, metrics);
    
    // Log if slow
    const threshold = PERFORMANCE_THRESHOLDS[operation];
    if (threshold && duration > threshold) {
      logger.warn(`Slow operation detected`, {
        component: 'performance',
        operation,
        performance: {
          duration,
          threshold,
          p95: this.calculateP95(metrics),
        },
      });
    }
  }
  
  private static calculateP95(values: number[]): number {
    const sorted = [...values].sort((a, b) => a - b);
    return sorted[Math.floor(sorted.length * 0.95)] || 0;
  }
}
