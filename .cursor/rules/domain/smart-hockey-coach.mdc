    },
  },
  
  FULL_FEEDBACK: {
    TECHNICAL: `Provide detailed technical analysis...`,
    MOTIVATIONAL: `Provide encouraging analysis...`,
    PRO_ANALYST: `Analyze like a professional broadcast analyst...`,
  },
} as const;

export function buildPrompt(
  type: 'fast' | 'full',
  options: PromptOptions
): string {
  // Type-safe prompt construction
  const template = type === 'fast' 
    ? PROMPT_TEMPLATES.FAST_FEEDBACK 
    : PROMPT_TEMPLATES.FULL_FEEDBACK[options.style];
    
  return interpolateTemplate(template, options);
}
