## Video Processing Standards

### Video Constraints
```typescript
// ✅ ALWAYS: Enforce video limits
export const VIDEO_CONSTRAINTS = {
  MAX_DURATION: 30, // seconds
  MAX_FILE_SIZE: {
    FAST: 1_048_576,   // 1MB
    FULL: 5_242_880,   // 5MB
  },
  RESOLUTION: {
    WIDTH: 1280,
    HEIGHT: 720,
  },
  FRAME_RATE: 30,
  BITRATE: {
    FAST: 3_000_000,   // 3 Mbps
    FULL: 5_000_000,   // 5 Mbps
  },
} as const;

// ✅ Video validation
export function validateVideoFile(
  file: VideoFile,
  type: 'fast' | 'full'
): Result<VideoFile, VideoError> {
  if (file.duration > VIDEO_CONSTRAINTS.MAX_DURATION) {
    return Err(new VideoError('Duration exceeds 30 seconds'));
  }
  
  if (file.size > VIDEO_CONSTRAINTS.MAX_FILE_SIZE[type.toUpperCase()]) {
    return Err(new VideoError(`File size exceeds ${type} limit`));
  }
  
  return Ok(file);
}
```

