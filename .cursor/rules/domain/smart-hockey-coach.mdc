## ML Model Integration

### TensorFlow Lite Setup
```typescript
// ✅ Model loading with error handling
export class ShotDetectionModel {
  private model: TFLiteModel | null = null;
  private isLoading = false;
  
  async initialize(): Promise<Result<void, ModelError>> {
    if (this.model || this.isLoading) return Ok(undefined);
    
    this.isLoading = true;
    try {
      const modelAsset = await loadModelAsset('shot_detection_v1.tflite');
      this.model = await TFLite.loadModel(modelAsset);
      
      // Warm up model
      await this.model.predict(createDummyFrame());
      
      return Ok(undefined);
    } catch (error) {
      return Err(new ModelError('Failed to load ML model', { cause: error }));
    } finally {
      this.isLoading = false;
    }
  }
  
  async detectShot(frame: VideoFrame): Promise<Result<ShotDetection | null>> {
    if (!this.model) {
      return Err(new ModelError('Model not initialized'));
    }
    
    try {
      const input = preprocessFrame(frame);
      const output = await this.model.predict(input);
      const detection = parsePrediction(output);
      
      if (detection.confidence < SHOT_DETECTION.CONFIDENCE_THRESHOLD) {
        return Ok(null);
      }
      
      return Ok(detection);
    } catch (error) {
      return Err(new ModelError('Prediction failed', { cause: error }));
    }
  }
}
```

