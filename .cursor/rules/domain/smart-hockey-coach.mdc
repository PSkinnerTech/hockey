### API Rate Limiting
```typescript
// ✅ Rate limiting for Gemini API
export class GeminiRateLimiter {
  private requestCounts = new Map<string, number>();
  private readonly limits = {
    DEVELOPER: { rpm: 60, rpd: 1500 },
    VERTEX_AI: { rpm: 300, rpd: 10000 },
  };
  
  async checkLimit(
    apiType: 'DEVELOPER' | 'VERTEX_AI'
  ): Promise<Result<void, RateLimitError>> {
    const now = Date.now();
    const minuteKey = `${apiType}:${Math.floor(now / 60000)}`;
    const dayKey = `${apiType}:${Math.floor(now / 86400000)}`;
    
    const minuteCount = this.requestCounts.get(minuteKey) || 0;
    const dayCount = this.requestCounts.get(dayKey) || 0;
    
    if (minuteCount >= this.limits[apiType].rpm) {
      return Err(new RateLimitError('Minute limit exceeded'));
    }
    
    if (dayCount >= this.limits[apiType].rpd) {
      return Err(new RateLimitError('Daily limit exceeded'));
    }
    
    this.requestCounts.set(minuteKey, minuteCount + 1);
    this.requestCounts.set(dayKey, dayCount + 1);
    
    return Ok(undefined);
  }
}
```

## Feedback Processing

### Progressive JSON Parsing
```typescript
// ✅ Safe progressive parsing for streaming responses
export class FeedbackParser {
  private buffer = '';
  
  appendChunk(chunk: string): ParsedFeedback {
    this.buffer += chunk;
    
    const parsed: ParsedFeedback = {
      complete: false,
      sections: {},
    };
    
    // Try to extract completed sections
    const extractors: Array<[keyof FeedbackSections, RegExp]> = [
      ['outcome', /"shot_outcome_full":\s*"([^"]+)"/],
      ['trajectory', /"puck_trajectory_description":\s*"([^"]+)"/],
      ['summary', /"overall_summary_and_encouragement":\s*"([^"]+)"/],
    ];
    
    for (const [key, regex] of extractors) {
      const match = this.buffer.match(regex);
      if (match) {
        parsed.sections[key] = match[1];
      }
    }
    
    // Check if JSON is complete
    try {
      const fullParsed = JSON.parse(this.buffer);
      parsed.complete = true;
      parsed.sections = fullParsed;
    } catch {
      // Still streaming
    }
    
    return parsed;
  }
}
```

## Performance Monitoring

### Latency Tracking
```typescript
// ✅ Track key performance metrics
export class PerformanceMonitor {
  private metrics: Map<string, number[]> = new Map();
  
  startTimer(operation: string): () => void {
    const start = performance.now();
    
    return () => {
      const duration = performance.now() - start;
      this.recordMetric(operation, duration);
    };
  }
  
  recordMetric(operation: string, value: number): void {
    const values = this.metrics.get(operation) || [];
    values.push(value);
    
    // Keep only last 100 values
    if (values.length > 100) {
      values.shift();
    }
    
    this.metrics.set(operation, values);
    
    // Log if exceeds threshold
    const threshold = PERFORMANCE_THRESHOLDS[operation];
    if (threshold && value > threshold) {
      logger.warn(`Performance threshold exceeded`, {
        operation,
        value,
        threshold,
        p95: this.getP95(operation),
      });
    }
  }
  
  getP95(operation: string): number {
    const values = this.metrics.get(operation) || [];
    if (values.length === 0) return 0;
    
    const sorted = [...values].sort((a, b) => a - b);
    const index = Math.floor(sorted.length * 0.95);
    return sorted[index];
  }
}

export const PERFORMANCE_THRESHOLDS = {
  'ml.shot_detection': 500,      // ms
  'video.extraction': 1000,       // ms
  'api.fast_feedback': 3000,      // ms
  'api.full_feedback': 15000,     // ms
  'ui.render_feedback': 100,      // ms
} as const;
