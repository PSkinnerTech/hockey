    message: string,
    public readonly code: 'LOAD' | 'PREDICT' | 'MEMORY',
    public readonly details?: unknown
  ) {
    super(message);
    this.name = 'MLModelError';
  }
}

export class GeminiAPIError extends Error {
  constructor(
    message: string,
    public readonly code: 'RATE_LIMIT' | 'CONTENT_FILTER' | 'TIMEOUT' | 'PARSE',
    public readonly statusCode?: number,
    public readonly details?: unknown
  ) {
    super(message);
    this.name = 'GeminiAPIError';
  }
}

// ✅ Error recovery strategies
export async function withRetry<T>(
  operation: () => Promise<Result<T>>,
  options: {
    maxAttempts: number;
    backoff: 'exponential' | 'linear';
    initialDelay: number;
  }
): Promise<Result<T>> {
  let lastError: Error | null = null;
  
  for (let attempt = 0; attempt < options.maxAttempts; attempt++) {
    const result = await operation();
    
    if (result.success) {
      return result;
    }
    
    lastError = result.error;
    
    // Check if error is retryable
    if (!isRetryableError(lastError)) {
      return result;
    }
    
    // Calculate delay
    const delay = options.backoff === 'exponential'
      ? options.initialDelay * Math.pow(2, attempt)
      : options.initialDelay * (attempt + 1);
      
    await sleep(Math.min(delay, 30000)); // Cap at 30s
  }
  
  return Err(lastError || new Error('Max retries exceeded'));
}
