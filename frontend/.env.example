# Environment Variables Template for Smart Hockey Coach
# Copy this file to .env.development, .env.staging, or .env.production

# Convex Configuration
EXPO_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-name

# API Keys (Development)
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false

# App Configuration
EXPO_PUBLIC_APP_NAME="Smart Hockey Coach"
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_BUILD_NUMBER=1

# URLs
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_SUPPORT_EMAIL=support@smarthockeycoach.com