<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Include most application data in backup -->
    <include domain="sharedpref" path="."/>
    <include domain="database" path="."/>
    <include domain="file" path="."/>
    
    <!-- Exclude sensitive information or temporary files -->
    <exclude domain="file" path="temp_videos"/>
    <exclude domain="file" path="cache"/>
    <exclude domain="sharedpref" path="device_credentials.xml"/>
</full-backup-content>